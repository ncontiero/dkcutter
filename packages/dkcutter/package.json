{
  "name": "dkcutter",
  "type": "module",
  "version": "6.2.0",
  "description": "A command-line utility that creates projects from templates.",
  "author": {
    "name": "Nicolas Contiero",
    "url": "https://github.com/ncontiero"
  },
  "license": "MIT",
  "homepage": "https://dkcutter.ncontiero.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ncontiero/dkcutter.git",
    "directory": "packages/dkcutter"
  },
  "bugs": {
    "url": "https://github.com/ncontiero/dkcutter/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./utils": "./dist/utils/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "dkcutter": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "start": "node dist/cli.mjs",
    "dev": "tsdown --watch",
    "clean": "git clean -xdf dist .turbo node_modules",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "ansis": "^4.3.1",
    "cac": "^7.0.0",
    "colorette": "2.0.20",
    "commander": "15.0.0",
    "isbinaryfile": "^6.0.0",
    "lilconfig": "^3.1.3",
    "nunjucks": "^3.2.4",
    "picospinner": "^3.0.0",
    "prompts": "^2.4.2",
    "semver": "^7.8.5",
    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.3.3",
    "@types/node": "26.1.1",
    "@types/nunjucks": "3.2.6",
    "@types/prompts": "2.4.9",
    "@types/semver": "7.7.1",
    "eslint": "10.6.0",
    "tsdown": "0.22.4",
    "type-fest": "5.8.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": "^22.3.0 || >=24.0.0"
  },
  "inlinedDependencies": {
    "type-fest": "5.8.0"
  }
}
