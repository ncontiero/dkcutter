{
  "name": "dkcutter",
  "type": "module",
  "version": "5.0.7",
  "description": "A command-line utility that creates projects from templates.",
  "author": {
    "name": "Nicolas Contiero",
    "url": "https://github.com/ncontiero"
  },
  "license": "MIT",
  "homepage": "https://dkcutter.ncontiero.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ncontiero/dkcutter.git",
    "directory": "packages/dkcutter"
  },
  "bugs": {
    "url": "https://github.com/ncontiero/dkcutter/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./utils": "./dist/utils/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "dkcutter": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "start": "node dist/cli.mjs",
    "dev": "tsdown --watch",
    "clean": "git clean -xdf dist .turbo node_modules",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "colorette": "^2.0.20",
    "commander": "^14.0.3",
    "lilconfig": "^3.1.3",
    "nunjucks": "^3.2.4",
    "picospinner": "^3.0.0",
    "prompts": "^2.4.2",
    "tinyexec": "^1.1.2",
    "tsx": "^4.22.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.2.1",
    "@types/node": "^25.8.0",
    "@types/nunjucks": "^3.2.6",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.4.0",
    "tsdown": "^0.22.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^22.3.0 || >=24.0.0"
  }
}
